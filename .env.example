# Local PostgreSQL configuration (no Docker required)
POSTGRES_DB=football_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/football_api
API_KEY=dev-api-key
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30
